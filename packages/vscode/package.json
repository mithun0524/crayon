{
  "name": "crayon-vscode",
  "displayName": "Crayon",
  "description": "Autonomous AI coding agent",
  "version": "0.5.1",
  "license": "MIT",
  "publisher": "crayon",
  "repository": {
    "type": "git",
    "url": "https://github.com/mithun0524/crayon.git",
    "directory": "packages/vscode"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#AF87FF",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onView:crayon.chatView",
    "onCommand:crayon.chat",
    "onCommand:crayon.runTask",
    "onCommand:crayon.indexWorkspace",
    "onCommand:crayon.setApiKey"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crayon.chat",
        "title": "Crayon: Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "crayon.runTask",
        "title": "Crayon: Run Task"
      },
      {
        "command": "crayon.indexWorkspace",
        "title": "Crayon: Index Workspace"
      },
      {
        "command": "crayon.setApiKey",
        "title": "Crayon: Set API Key (stored securely)"
      },
      {
        "command": "crayon.clearChat",
        "title": "Crayon: Clear Conversation",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "crayon-sidebar",
          "title": "Crayon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "crayon-sidebar": [
        {
          "type": "webview",
          "id": "crayon.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Crayon",
      "properties": {
        "crayon.anthropicApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Anthropic API key for Claude models. **Prefer `Crayon: Set API Key` (secure storage)** — this setting is kept as a fallback and syncs in plain text."
        },
        "crayon.openaiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "OpenAI API key. **Prefer `Crayon: Set API Key` (secure storage).**"
        },
        "crayon.openrouterApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "OpenRouter API key. **Prefer `Crayon: Set API Key` (secure storage).**"
        },
        "crayon.googleApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Google AI (Gemini) API key. **Prefer `Crayon: Set API Key` (secure storage).**"
        },
        "crayon.provider": {
          "type": "string",
          "enum": [
            "openrouter",
            "anthropic",
            "openai",
            "google",
            "ollama"
          ],
          "default": "anthropic",
          "description": "LLM provider. \"ollama\" talks to a local Ollama server (OLLAMA_BASE_URL or http://localhost:11434) and needs no API key."
        },
        "crayon.defaultModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Default model for agent tasks"
        },
        "crayon.permissionMode": {
          "type": "string",
          "enum": [
            "ask",
            "auto-edit",
            "plan",
            "auto",
            "bypass"
          ],
          "enumDescriptions": [
            "Confirm every edit and command",
            "Apply edits automatically; confirm commands",
            "Plan only — never change files or run commands",
            "Act freely; block dangerous commands",
            "No prompts (use with care)"
          ],
          "default": "auto-edit",
          "description": "How much Crayon can do on its own — mirrors the terminal's /mode."
        },
        "crayon.autoApplyEdits": {
          "type": "boolean",
          "default": true,
          "description": "Deprecated — use crayon.permissionMode. Only used if permissionMode is unset."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "crayon.clearChat",
          "when": "view == crayon.chatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "node scripts/package.cjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@lancedb/lancedb": "^0.30.0",
    "@vscode/ripgrep": "^1.18.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.3.0",
    "crayon-agent": "workspace:*",
    "crayon-indexer": "workspace:*",
    "dompurify": "^3.2.4",
    "esbuild": "^0.25.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "typescript": "^5.8.2"
  }
}
