{
  "name": "crayon-cli",
  "version": "0.1.6",
  "type": "module",
  "bin": {
    "crayon": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binaries": "node scripts/build-binaries.cjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "pkg": {
    "scripts": "dist/**/*.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/marked-terminal": "^6.1.1",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "crayon-agent": "workspace:*",
    "crayon-indexer": "workspace:*",
    "diff": "^9.0.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "posthog-node": "^4.18.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/ink-text-input": "^2.0.5",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "pkg": "^5.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
