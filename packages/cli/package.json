{
  "name": "crayon-cli",
  "version": "0.2.0",
  "description": "An AI-powered terminal coding assistant that can search your codebase, create plans, and automatically execute them.",
  "author": "mithun0524",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mithun0524/crayon"
  },
  "homepage": "https://crayon-umber.vercel.app",
  "keywords": [
    "ai",
    "cli",
    "assistant",
    "terminal",
    "coding",
    "agent",
    "developer-tools",
    "copilot"
  ],
  "type": "module",
  "bin": {
    "crayon": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:binaries": "node scripts/build-binaries.cjs",
    "dev": "tsx src/index.ts",
    "start": "node ./dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "pkg": {
    "scripts": "dist/**/*.js"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@lancedb/lancedb": "^0.30.0",
    "@vscode/ripgrep": "^1.15.9",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@types/ink-select-input": "^3.0.5",
    "@types/ink-testing-library": "^1.0.4",
    "@types/ink-text-input": "^2.0.5",
    "@types/marked": "^6.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "chalk": "^5.4.1",
    "cli-highlight": "^2.1.11",
    "commander": "^13.1.0",
    "crayon-agent": "workspace:*",
    "crayon-indexer": "workspace:*",
    "diff": "^9.0.0",
    "esbuild": "^0.25.0",
    "ink": "^5.2.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^8.2.0",
    "pkg": "^5.8.1",
    "posthog-node": "^4.18.0",
    "react": "^18.3.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
